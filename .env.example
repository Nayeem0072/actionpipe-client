# Auth0 (copy to .env and fill in from Auth0 Dashboard)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id
# API audience (required for /me; set to your Auth0 API identifier)
# VITE_AUTH0_AUDIENCE=https://your-api.example.com

# Backend API (optional; defaults to http://localhost:8000)
# VITE_API_URL=http://localhost:8000
